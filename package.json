{
  "name": "jungle-bay-island-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "backend",
    "island"
  ],
  "scripts": {
    "build:frontend": "./scripts/build.sh",
    "deploy:backend": "./scripts/deploy-backend.sh",
    "dev:backend": "cd backend && bun run dev",
    "dev:frontend": "cd island && bun run dev",
    "typecheck:backend": "cd backend && bun run typecheck",
    "typecheck:frontend": "cd island && bun run typecheck",
    "typecheck": "bun run typecheck:backend && bun run typecheck:frontend"
  }
}
